def ispalindrome(n):
    x=str(n)
    if len(x)<=1:
        return True
    else:
        i=0
        j=len(x)-1
        while i<=j:
            if x[i]!=x[j]:
                return False
            i+=1
            j-=1
        return True
def next(n):
    x=n+1
    while True:
        if ispalindrome(x):
            return x
        x+=1

