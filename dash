Total Chocolates From Wrapper Scheme
money = 15
cost = 1
wrap_req = 3
output
22

def TotalChocolates(money, cost, wrap_req):
    choc=money//cost
    wrappers=choc
    while wrappers>=wrap_req:
        new_choc=wrappers//wrap_req
        choc+=new_choc
        wrappers=(wrappers%wrap_req)+new_choc
    return choc
