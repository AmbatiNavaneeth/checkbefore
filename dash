Merge Dictionaries with Sum
def mergeDict(d1, d2): #adding first dict to res then adding dict2 to res
res={}
for key in d1:
    res[key]=d1[key]
for key in d2:
    if key in res:
        res[key]+=d2[key]
    else:
         res[key]=d2[key]
return res
