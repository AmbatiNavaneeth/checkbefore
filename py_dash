A strong number is a number whose sum of the factorials of its digits is equal to the number itself.
Input    
numbers = [145, 10, 2, 40585]
Output
[0, 2, 3]

import math
def StrongNumberIndexFinder(numbers):
  res=[]
  for i in range(len(numbers)):
    ans=numbers[i]
    t=0
    for digit in str(ans):
        t+=math.factorial(int(digit))
    if t==ans:
        res.append(i)
  return res
