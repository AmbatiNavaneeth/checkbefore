def wordPattern(pattern, s):
    words=s.split()
    if len(pattern)!=len(words):
        return False
    ch_to_word={}
    word_to_ch={}
    for ch,word in zip(pattern,words):
        if ch in ch_to_word:
            if ch_to_word[ch]!= word:
                return False
        else:
            ch_to_word[ch]=word
        if word in word_to_ch:
            if word_to_ch[word]!=ch:
                return False
        else:
            word_to_ch[word]=ch
    return True
