N = 4
A = [1, 5, 7, 4]
B = [3, 8, 2, 10]

def max_team_a_wins(N, A, B):
    A.sort()
    B.sort()
    i=0
    j=0
    win=0
    while i<len(A) and j<len(B):
        if A[i]>B[j]:
            win+=1
            i+=1
            j+=1
        else:
            i+=1
    return win
